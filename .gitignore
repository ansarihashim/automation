# =============================================================================
# ROOT .gitignore — Kiirus Automation
# =============================================================================

# ── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python / Backend ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pdb
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
ENV/

# ── Pytest / Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.xml

# ── Node / Frontend ──────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/dist-ssr/
*.local

# ── Batch Storage (runtime data — never commit) ──────────────────────────────
backend/app/storage/batches/
backend/app/storage/logs/
backend/app/storage/master_files/

# ── OS & Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
